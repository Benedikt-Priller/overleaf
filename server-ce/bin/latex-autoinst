#!/bin/bash
# Wrapper script for latex command with automatic package installation
# This script runs latex and automatically installs missing packages

set -e
set -o pipefail

TEXLIVE_MIRROR="${TEXLIVE_MIRROR:-https://mirror.ox.ac.uk/sites/ctan.org/systems/texlive/tlnet}"
TEXLIVE_FALLBACK_MIRRORS=("https://mirror.ctan.org/systems/texlive/tlnet" "https://ctan.math.utah.edu/ctan/tex-archive/systems/texlive/tlnet")
MAX_ATTEMPTS=3
ATTEMPT=0
INSTALLED_PACKAGES=()

LATEX_BIN="${LATEX_REAL_BIN:-}"
if [ -z "$LATEX_BIN" ]; then
    LATEX_BIN="$(ls -1d /usr/local/texlive/[0-9][0-9][0-9][0-9]/bin/x86_64-linux/latex 2>/dev/null | sort -V | tail -1 || true)"
fi
if [ -z "$LATEX_BIN" ]; then
    LATEX_BIN="$(command -v latex 2>/dev/null || true)"
fi
if [ -z "$LATEX_BIN" ] || [ "$LATEX_BIN" = "/usr/local/bin/latex" ]; then
    echo "===== AutoInstall: unable to resolve real latex binary =====" >&2
    exit 127
fi

# Verify wrapper is actually being invoked (prevent symlink bypass)
if [ "$0" = "/usr/local/bin/latex" ] && [ -L "$0" ]; then
    echo "===== AutoInstall: WARNING - latex is still a symlink, wrapper may be bypassed ====="  >&2
fi

echo "===== AutoInstall: Using latex binary: $LATEX_BIN ====="  >&2

# Extract filename from LaTeX error message (broaden patterns for robustness)
extract_filename() {
    local line="$1"
    
    # Pattern 1: File `package.sty' not found
    if [[ $line =~ File\ \`([^\']+)\.sty\'\ not\ found ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    # Pattern 2: File `package.cls' not found  
    if [[ $line =~ File\ \`([^\']+)\.cls\'\ not\ found ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    # Pattern 3: I can't find file `package'
    if [[ $line =~ I\ can\'t\ find\ file\ \`([^\']+)\' ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    
    return 1
}

# Try installing package by filename (always resolve via tlmgr search --file first)
try_install_package() {
    local missing="$1"
    local pkg=""
    
    # Avoid reinstalling the same filename
    if [[ " ${INSTALLED_PACKAGES[@]} " =~ " ${missing} " ]]; then
        echo "===== AutoInstall: Already attempted to install '$missing', skipping ====="  >&2
        return 1
    fi
    
    INSTALLED_PACKAGES+=("$missing")
    
    echo "===== AutoInstall: Resolving missing file '$missing' ====="  >&2
    
    # ALWAYS resolve via tlmgr search --file first (most reliable strategy)
    for repo in "$TEXLIVE_MIRROR" "${TEXLIVE_FALLBACK_MIRRORS[@]}"; do
        echo "===== AutoInstall: Searching for package providing /${missing}.sty in $repo ====="  >&2
        pkg="$(tlmgr search --global --file "/${missing}.sty" 2>/dev/null | awk -F: '/:/{print $1; exit}' || true)"
        if [ -z "$pkg" ]; then
            pkg="$(tlmgr search --global --file "/${missing}.cls" 2>/dev/null | awk -F: '/:/{print $1; exit}' || true)"
        fi
        if [ -n "$pkg" ]; then
            echo "===== AutoInstall: Resolved '$missing' -> tlmgr package '$pkg' ====="  >&2
            break
        fi
    done
    
    if [ -z "$pkg" ]; then
        echo "===== AutoInstall: FAILED to resolve any package for '$missing' ====="  >&2
        return 1
    fi
    
    # Install the resolved package (with mirror fallback)
    for repo in "$TEXLIVE_MIRROR" "${TEXLIVE_FALLBACK_MIRRORS[@]}"; do
        echo "===== AutoInstall: Installing resolved package '$pkg' from $repo ====="  >&2
        if tlmgr install --repository "$repo" "$pkg" 2>&1; then
            echo "===== AutoInstall: Successfully installed '$pkg' ====="  >&2
            mktexlsr >/dev/null 2>&1 || true
            return 0
        fi
    done
    
    echo "===== AutoInstall: FAILED to install resolved package '$pkg' from all mirrors ====="  >&2
    return 1
}

# Main compilation loop with auto-install
while [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do
    ATTEMPT=$((ATTEMPT + 1))
    
    # Run the actual latex command
    if "$LATEX_BIN" "$@" 2>&1 | tee /tmp/latex_output.txt; then
        # Success
        exit 0
    else
        EXIT_CODE=$?
        
        # Check if there's a missing package error in the output
        PACKAGE_FOUND=0
        while IFS= read -r line; do
            if MISSING=$(extract_filename "$line"); then
                if try_install_package "$MISSING"; then
                    PACKAGE_FOUND=1
                    break
                fi
            fi
        done < /tmp/latex_output.txt
        
        # If we found and installed a package, retry
        if [ $PACKAGE_FOUND -eq 1 ]; then
            echo "===== AutoInstall: Retrying latex after package installation =====" >&2
            continue
        fi
        
        # If no package found or installation failed, exit with original error
        exit $EXIT_CODE
    fi
done

echo "===== AutoInstall: Max attempts ($MAX_ATTEMPTS) reached =====" >&2
exit 1
