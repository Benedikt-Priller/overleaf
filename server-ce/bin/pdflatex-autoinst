#!/bin/bash
# Wrapper script for pdflatex command with automatic package installation
# This script runs pdflatex and automatically installs missing packages

set -e
set -o pipefail

TEXLIVE_MIRROR="${TEXLIVE_MIRROR:-https://mirror.ox.ac.uk/sites/ctan.org/systems/texlive/tlnet}"
TEXLIVE_FALLBACK_MIRRORS=("https://mirror.ctan.org/systems/texlive/tlnet" "https://ctan.math.utah.edu/ctan/tex-archive/systems/texlive/tlnet")
MAX_ATTEMPTS=3
ATTEMPT=0
INSTALLED_PACKAGES=()

ai_log() {
    echo "$*"
    echo "$*" >&2
}

PDFLATEX_BIN="${PDFLATEX_REAL_BIN:-}"
if [ -z "$PDFLATEX_BIN" ]; then
    PDFLATEX_BIN="$(ls -1d /usr/local/texlive/[0-9][0-9][0-9][0-9]/bin/x86_64-linux/pdflatex 2>/dev/null | sort -V | tail -1 || true)"
fi
if [ -z "$PDFLATEX_BIN" ]; then
    PDFLATEX_BIN="$(command -v pdflatex 2>/dev/null || true)"
fi
if [ -z "$PDFLATEX_BIN" ] || [ "$PDFLATEX_BIN" = "/usr/local/bin/pdflatex" ]; then
    ai_log "===== AutoInstall: unable to resolve real pdflatex binary ====="
    exit 127
fi

# Verify wrapper is actually being invoked (prevent symlink bypass)
if [ "$0" = "/usr/local/bin/pdflatex" ] && [ -L "$0" ]; then
    ai_log "===== AutoInstall: WARNING - pdflatex is still a symlink, wrapper may be bypassed ====="
fi

ai_log "===== AutoInstall: Using pdflatex binary: $PDFLATEX_BIN ====="

# Extract filename from LaTeX error message (broaden patterns for robustness)
extract_filename() {
    local line="$1"
    
    # Pattern 1: File `package.sty' not found
    if [[ $line =~ File\ \`([^\']+)\.sty\'\ not\ found ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    # Pattern 2: File `package.cls' not found  
    if [[ $line =~ File\ \`([^\']+)\.cls\'\ not\ found ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    # Pattern 3: I can't find file `package'
    if [[ $line =~ I\ can\'t\ find\ file\ \`([^\']+)\' ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    
    return 1
}

# Find a missing package marker across likely compile outputs.
find_missing_filename() {
    local source_file
    local line
    for source_file in "/tmp/pdflatex_output.txt" "output.log" "$PWD/output.log"; do
        [ -f "$source_file" ] || continue
        while IFS= read -r line; do
            if extract_filename "$line"; then
                return 0
            fi
        done < "$source_file"
    done
    return 1
}

# Try installing package by filename (always resolve via tlmgr search --file first)
resolve_tlmgr_package() {
    local missing="$1"
    local pkg=""
    pkg="$(tlmgr search --global --file "/${missing}.sty" 2>/dev/null | awk '/^[[:alnum:]._-]+:$/ { sub(/:$/, "", $1); print $1; exit }' || true)"
    if [ -z "$pkg" ]; then
        pkg="$(tlmgr search --global --file "/${missing}.cls" 2>/dev/null | awk '/^[[:alnum:]._-]+:$/ { sub(/:$/, "", $1); print $1; exit }' || true)"
    fi
    echo "$pkg"
}

try_install_package() {
    local missing="$1"
    local pkg=""
    
    # Avoid reinstalling the same filename
    if [[ " ${INSTALLED_PACKAGES[@]} " =~ " ${missing} " ]]; then
        ai_log "===== AutoInstall: Already attempted to install '$missing', skipping ====="
        return 1
    fi
    
    INSTALLED_PACKAGES+=("$missing")
    
    ai_log "===== AutoInstall: Resolving missing file '$missing' ====="
    
    # ALWAYS resolve via tlmgr search --file first (most reliable strategy)
    for repo in "$TEXLIVE_MIRROR" "${TEXLIVE_FALLBACK_MIRRORS[@]}"; do
        ai_log "===== AutoInstall: Searching for package providing /${missing}.sty in $repo ====="
        pkg="$(resolve_tlmgr_package "$missing")"
        if [ -n "$pkg" ]; then
            ai_log "===== AutoInstall: Resolved '$missing' -> tlmgr package '$pkg' ====="
            break
        fi
    done
    
    if [ -z "$pkg" ]; then
        ai_log "===== AutoInstall: FAILED to resolve any package for '$missing' ====="
        return 1
    fi
    
    # Install the resolved package (with mirror fallback)
    for repo in "$TEXLIVE_MIRROR" "${TEXLIVE_FALLBACK_MIRRORS[@]}"; do
        ai_log "===== AutoInstall: Installing resolved package '$pkg' from $repo ====="
        if tlmgr install --repository "$repo" "$pkg" 2>&1; then
            ai_log "===== AutoInstall: Successfully installed '$pkg' ====="
            mktexlsr >/dev/null 2>&1 || true
            return 0
        fi
    done
    
    ai_log "===== AutoInstall: FAILED to install resolved package '$pkg' from all mirrors ====="
    return 1
}

# Main compilation loop with auto-install
while [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do
    ATTEMPT=$((ATTEMPT + 1))
    
    # Run the actual pdflatex command
    if "$PDFLATEX_BIN" "$@" 2>&1 | tee /tmp/pdflatex_output.txt; then
        # Success
        exit 0
    else
        EXIT_CODE=$?
        
        # Check if there's a missing package error in compile output/log files
        PACKAGE_FOUND=0
        if MISSING=$(find_missing_filename); then
            if try_install_package "$MISSING"; then
                PACKAGE_FOUND=1
            fi
        fi
        
        # If we found and installed a package, retry
        if [ $PACKAGE_FOUND -eq 1 ]; then
            ai_log "===== AutoInstall: Retrying pdflatex after package installation ====="
            continue
        fi
        
        # If no package found or installation failed, exit with original error
        exit $EXIT_CODE
    fi
done

ai_log "===== AutoInstall: Max attempts ($MAX_ATTEMPTS) reached ====="
exit 1
