# --------------------------------------------------
# Overleaf Base Image (sharelatex/sharelatex-base)
# --------------------------------------------------

ARG BASE_IMAGE=phusion/baseimage:noble-1.0.2
FROM ${BASE_IMAGE}

# Makes sure LuaTex cache is writable
# -----------------------------------
ENV TEXMFVAR=/var/lib/overleaf/tmp/texmf-var

# Update to ensure dependencies are updated
# ------------------------------------------
ENV REBUILT_AFTER="2026-01-13"

# Install dependencies
# --------------------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
# Technically, we are using potentially stale package-lists with the below line.
# Practically, apt refreshes the lists as needed and release builds run in fresh CI VMs without the cache.
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked true \
# Enable caching: https://docs.docker.com/reference/dockerfile/#example-cache-apt-packages
&&  rm -f /etc/apt/apt.conf.d/docker-clean && echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' > /etc/apt/apt.conf.d/keep-cache \
&&  apt-get update \
&&  apt-get install -y \
      unattended-upgrades \
      build-essential wget net-tools unzip time poppler-utils optipng strace nginx git python3 python-is-python3 zlib1g-dev libpcre3-dev gettext-base libwww-perl ca-certificates curl gnupg \
      qpdf \
# upgrade base-image, batch all the upgrades together, rather than installing them on-by-one (which is slow!)
&&  unattended-upgrade --verbose --no-minimal-upgrade-steps \
# install Node.js https://github.com/nodesource/distributions#nodejs
&&  mkdir -p /etc/apt/keyrings \
&&  curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
&&  echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
&&  apt-get update \
&&  apt-get install -y nodejs \
    \
&&  rm -rf \
# We are adding a custom nginx config in the main Dockerfile.
      /etc/nginx/nginx.conf \
      /etc/nginx/sites-enabled/default

# Install TexLive
# ---------------
# CTAN mirrors occasionally fail, in that case install TexLive using a
# different server, for example https://ctan.crest.fr
#
# # docker build \
#     --build-arg TEXLIVE_MIRROR=https://ctan.crest.fr/tex-archive/systems/texlive/tlnet \
#     -f Dockerfile-base -t sharelatex/sharelatex-base .
ARG TEXLIVE_MIRROR=https://mirror.ox.ac.uk/sites/ctan.org/systems/texlive/tlnet
ARG TEXLIVE_FALLBACK_MIRRORS="https://mirror.ctan.org/systems/texlive/tlnet https://ctan.math.utah.edu/ctan/tex-archive/systems/texlive/tlnet"

RUN set -eux; \
            mkdir /install-tl-unx; \
            wget --quiet https://tug.org/texlive/files/texlive.asc; \
            gpg --batch --import texlive.asc; \
            rm texlive.asc; \
            SELECTED_MIRROR=""; \
            for mirror in "${TEXLIVE_MIRROR}" ${TEXLIVE_FALLBACK_MIRRORS}; do \
                  echo "Trying TeX Live mirror: ${mirror}"; \
                  if wget --tries=3 --timeout=30 --waitretry=5 --retry-connrefused --quiet -O install-tl-unx.tar.gz "${mirror}/install-tl-unx.tar.gz" \
                        && wget --tries=3 --timeout=30 --waitretry=5 --retry-connrefused --quiet -O install-tl-unx.tar.gz.sha512 "${mirror}/install-tl-unx.tar.gz.sha512" \
                        && wget --tries=3 --timeout=30 --waitretry=5 --retry-connrefused --quiet -O install-tl-unx.tar.gz.sha512.asc "${mirror}/install-tl-unx.tar.gz.sha512.asc" \
                        && gpg --batch --verify install-tl-unx.tar.gz.sha512.asc install-tl-unx.tar.gz.sha512 \
                        && sha512sum -c install-tl-unx.tar.gz.sha512; then \
                        SELECTED_MIRROR="${mirror}"; \
                        break; \
                  fi; \
                  rm -f install-tl-unx.tar.gz install-tl-unx.tar.gz.sha512 install-tl-unx.tar.gz.sha512.asc; \
            done; \
            if [ -z "${SELECTED_MIRROR}" ]; then \
                  echo "Unable to fetch and verify TeX Live installer from all configured mirrors"; \
                  exit 1; \
            fi; \
            echo "${SELECTED_MIRROR}" > /tmp/texlive-mirror; \
            tar -xz -C /install-tl-unx --strip-components=1 -f install-tl-unx.tar.gz; \
            rm -f install-tl-unx.tar.gz install-tl-unx.tar.gz.sha512 install-tl-unx.tar.gz.sha512.asc; \
            echo "tlpdbopt_autobackup 0" >> /install-tl-unx/texlive.profile; \
            echo "tlpdbopt_install_docfiles 0" >> /install-tl-unx/texlive.profile; \
            echo "tlpdbopt_install_srcfiles 0" >> /install-tl-unx/texlive.profile; \
            echo "selected_scheme scheme-basic" >> /install-tl-unx/texlive.profile; \
            /install-tl-unx/install-tl \
                  -profile /install-tl-unx/texlive.profile \
                  -repository "${SELECTED_MIRROR}"; \
            TLMGR_BIN="$(find /usr/local/texlive -name tlmgr | head -n 1)"; \
            "${TLMGR_BIN}" path add; \
            echo "${SELECTED_MIRROR}" > /tmp/texlive-mirror; \
            tlmgr path add; \
            rm -rf /install-tl-unx

# Install commonly-used LaTeX packages to reduce compilation time
# This provides a good baseline for most academic and technical documents
# Users can still install additional packages via the auto-install mechanism
# -----------------------------------------------------------------
RUN set -eux; \
    TEXLIVE_REPO="${TEXLIVE_MIRROR}"; \
    if [ -f /tmp/texlive-mirror ]; then TEXLIVE_REPO="$(cat /tmp/texlive-mirror)"; fi; \
    INSTALL_OK=""; \
    for repo in "${TEXLIVE_REPO}" ${TEXLIVE_FALLBACK_MIRRORS}; do \
                  echo "Installing TeX package group 1 from ${repo}"; \
                  if tlmgr install --no-execute-actions --repository "${repo}" \
                        latexmk texcount synctex etoolbox xetex \
                        amsfonts amsmath amssymb babel babelbib beamer bidi bookmark booktabs breakurl caption cite color colortbl csquotes enumitem eso-pic etoc \
                        fancyhdr fancyvrb fontspec float fontawesome5 geometry glossaries graphicx grffile graphics hyperref iftex inputenc \
                        kantlipsum koma-script lastpage listings lmodern logreq makechap makeindex marginnote marvosym mathtools microtype minted \
                        natbib notoccite palatino paralist parskip pdfpages pgf polyglossia preview \
                        2>&1 | tee /tmp/tlmgr-install.log; then \
        INSTALL_OK="1"; \
        break; \
      fi; \
                  if grep -q "package already present" /tmp/tlmgr-install.log; then \
        INSTALL_OK="1"; \
        break; \
      fi; \
    done; \
    if [ -z "${INSTALL_OK}" ]; then \
                  echo "Failed to install TeX package group 1 from all configured repositories"; \
      exit 1; \
            fi

RUN set -eux; \
            TEXLIVE_REPO="${TEXLIVE_MIRROR}"; \
            if [ -f /tmp/texlive-mirror ]; then TEXLIVE_REPO="$(cat /tmp/texlive-mirror)"; fi; \
            INSTALL_OK=""; \
            for repo in "${TEXLIVE_REPO}" ${TEXLIVE_FALLBACK_MIRRORS}; do \
                  echo "Installing TeX package group 2 from ${repo}"; \
                  if tlmgr install --no-execute-actions --repository "${repo}" \
                        ragged2e soul splitindex subfig table template texshade tgbonum tgcadm tgcursor tgheros tgpagella \
                        tikz tikzmark titlesec tocloft todonotes unicode-math units url utopia varwidth verbatim wasysym wrapfig xcolor xkeyval \
                        2>&1 | tee /tmp/tlmgr-install.log; then \
                        INSTALL_OK="1"; \
                        break; \
                  fi; \
                  if grep -q "package already present" /tmp/tlmgr-install.log; then \
                        INSTALL_OK="1"; \
                        break; \
                  fi; \
            done; \
            if [ -z "${INSTALL_OK}" ]; then \
                  echo "Failed to install TeX package group 2 from all configured repositories"; \
                  exit 1; \
            fi

RUN set -eux; \
            TEXLIVE_REPO="${TEXLIVE_MIRROR}"; \
            if [ -f /tmp/texlive-mirror ]; then TEXLIVE_REPO="$(cat /tmp/texlive-mirror)"; fi; \
            INSTALL_OK=""; \
            for repo in "${TEXLIVE_REPO}" ${TEXLIVE_FALLBACK_MIRRORS}; do \
                  echo "Installing TeX package group 3 (user templates) from ${repo}"; \
                  if tlmgr install --no-execute-actions --repository "${repo}" \
                        acronym algorithm2e arydshln array cancel calc chemfig chngcntr comment dsfont eurosym floatflt forest gauss glossaries-light ifthen import lscape longtable makecell mhchem multicol multirow newpxmath nicefrac nicematrix nomencl pdflscape pgfplots relsize scalerel setspace siunitx svg tcolorbox theoremref tikz-cd tikzsymbols todonotes-tcolorbox translations transparent ulem varwidth varioref venndiagram vhistory witharrows xfrac xifthen xspace \
                        2>&1 | tee /tmp/tlmgr-install.log; then \
                        INSTALL_OK="1"; \
                        break; \
                  fi; \
                  if grep -q "package already present" /tmp/tlmgr-install.log; then \
                        INSTALL_OK="1"; \
                        break; \
                  fi; \
            done; \
            if [ -z "${INSTALL_OK}" ]; then \
                  echo "Failed to install TeX package group 3 from all configured repositories"; \
                  exit 1; \
            fi

RUN set -eux; \
            mktexlsr || true; \
            updmap-sys || true; \
            rm -f /tmp/texlive-mirror /tmp/tlmgr-install.log

# Setup pdflatex-autoinst wrapper to intercept compiler calls and auto-install missing packages
RUN TEXLIVE_YEAR=$(ls -1 /usr/local/texlive/ | grep '^20[0-9][0-9]$' | sort -n | tail -1) && \
    if [ -z "$TEXLIVE_YEAR" ]; then echo "TeX Live not found"; exit 1; fi && \
    REAL_PDFLATEX="/usr/local/texlive/$TEXLIVE_YEAR/bin/x86_64-linux/pdflatex" && \
    if [ -f "/usr/local/bin/pdflatex-autoinst" ]; then \
      sed -i "s|PDFLATEX_BIN=.*|PDFLATEX_BIN=\"$REAL_PDFLATEX\"|" /usr/local/bin/pdflatex-autoinst && \
      rm -f /usr/local/bin/pdflatex && \
      cp /usr/local/bin/pdflatex-autoinst /usr/local/bin/pdflatex && \
      chmod +x /usr/local/bin/pdflatex && \
      echo "pdflatex autoinst wrapper installed"; \
    fi

# Set up overleaf user and home directory
# -----------------------------------------
RUN adduser --system --group --home /overleaf --no-create-home overleaf && \
	mkdir -p /var/lib/overleaf && \
	chown www-data:www-data /var/lib/overleaf && \
	mkdir -p /var/log/overleaf && \
	chown www-data:www-data /var/log/overleaf && \
	mkdir -p /var/lib/overleaf/data/template_files && \
	chown www-data:www-data /var/lib/overleaf/data/template_files
