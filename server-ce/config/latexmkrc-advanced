# ====================
# Parallel Compilation
# ====================

# Number of parallel jobs for latexmk (requires -j flag or here)
# Also requires pdflatex to be run with multiple -src-specials
# This can speed up large documents
# $jobs = 4;

# ====================
# Environment Variables
# ====================

# Ensure certain environment variables are passed through
# This is useful for package-specific configurations
# $ENV{'LUA_PATH'} = '/path/to/lua/modules' if defined $ENV{'LUA_PATH'};

# ====================
# Troubleshooting Tips
# ====================

# 1. To see what latexmk is doing, run with -verbose
# 2. To force full rebuild, use latexmk -C (clean all) before compiling
# 3. To see all rules being applied, use -version
# 4. Check latexmk manual for more options: man latexmk

# Examples of common issues and fixes:
# 
# Issue: Bibliography not updating
# Fix: Add these lines above:
# $bibtex = 'bibtex %O %B';
# add_cus_dep('aux', 'bbl', 0, 'my_bibtex');
#
# Issue: Glossaries not generated
# Fix: Ensure glossaries package is installed and use:
# push @generated_exts, 'glo', 'gls';
#
# Issue: Compilation hangs
# Fix: Increase max_repeat or check for infinite loops in your LaTeX

# ====================
# Notes for Overleaf Users
# ====================

# 1. This file will be used if placed in your project root
# 2. It's recommended to use the minimal configuration needed
# 3. The auto-installation wrapper scripts are always active
# 4. Large documents benefit from the $go_mode = 3 setting
# 5. For very large projects, consider breaking into smaller files with \input
